# ============================================================
# milb-tracker 环境配置模板
# 使用方式：将此文件复制为 .env，按需修改后放置于以下任一位置：
#   - 项目根目录（CWD）：仅对当前项目生效，优先级最高
#   - ~/.config/milb-tracker/.env ：用户级全局配置，优先级次之
#
# 加载优先级（从高到低）：
#   1. 进程环境变量（export DB_PATH=...）
#   2. CWD/.env（本文件所在位置）
#   3. ~/.config/milb-tracker/.env
#   4. 内置默认值
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
# SQLite 数据库文件路径
# 默认值：{CWD}/data/bids.db
DB_PATH=/home/paul/.openclaw/workspace/military-bidding/data/bids.db

# ── 附件存储 ─────────────────────────────────────────────────
# 招标公告及标书附件的存储根目录
# 默认值：DB_PATH 同级的 attachments/ 子目录
# 结构：{ATTACHMENTS_DIR}/{project_id}/filename.pdf
ATTACHMENTS_DIR=/home/paul/.openclaw/workspace/military-bidding/attachments
